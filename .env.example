# Copy this file to .env and fill in your values.
# Variables set here override the corresponding fields in config.yaml.
# .env is gitignored — never commit it.

# Required: target Google Calendar ID (Settings → Integrate calendar → Calendar ID)
GOOGLE_CALENDAR_ID=your-id@group.calendar.google.com

# Optional overrides (can also be set in config.yaml)
# TIMETABLE_URL=https://your-university.example/timetable.xls
# GOOGLE_APPLICATION_CREDENTIALS=credentials/service_account.json
